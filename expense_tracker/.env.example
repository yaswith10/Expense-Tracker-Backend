# Required in all environments
SECRET_KEY=your-secret-key-here

# Required in production only
# Comma-separated, no spaces
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
CORS_ALLOWED_ORIGINS=https://yourdomain.com

# Required for AI insights endpoint
# Obtain a free API key from https://console.groq.com
# Set LLM_API_KEY to your Groq key. To use a different provider,
# update the engine implementation in expenses/ai/engines/ accordingly.
LLM_API_KEY=your-llm-api-key-here
